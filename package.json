{
  "name": "@rvct/phoenix",
  "version": "1.1.0-beta.1",
  "packageManager": "pnpm@10.26.2",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ravecat/phoenix.git"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "phoenix",
    "phoenix-channels",
    "channels",
    "websocket",
    "realtime",
    "reactive",
    "state",
    "nanostores"
  ],
  "scripts": {
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "format": "biome format --write . && pnpm run format:md",
    "format:md": "prettier --write \"*.md\"",
    "lint": "biome check . && pnpm run lint:md",
    "lint:fix": "biome check --write . && pnpm run format:md",
    "lint:md": "prettier --check \"*.md\"",
    "release": "semantic-release",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@types/phoenix": "^1.6.7",
    "nanostores": "^1.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "prettier": "^3.8.3",
    "semantic-release": "25.0.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
