{
  "name": "@rvct/phoenix",
  "version": "0.0.0",
  "packageManager": "pnpm@10.26.2",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ravecat/phoenix.git"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "pnpm run lint && pnpm run typecheck",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@types/phoenix": "^1.6.7",
    "nanostores": "^1.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "typescript": "^5.9.3"
  }
}
